; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="malatang"
run/main_scene="res://scenes/menus/title_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

ProgressData="*res://autoload/progress_data.gd"
RunSetupData="*res://autoload/run_setup_data.gd"
TextDB="*res://autoload/text_db.gd"
GlobalRunMenu="*res://autoload/global_run_menu.gd"
EffectManager="*res://autoload/effect_manager.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"

